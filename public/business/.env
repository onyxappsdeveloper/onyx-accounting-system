# Application Environment
APP_ENV=production
APP_NAME=ONYX Accounting ERP
APP_URL=https://business.onyxtechpay.com
APP_DEBUG=false

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u963586588_Business
DB_USER=u963586588_user
DB_PASS=your_db_password_here
DB_CHARSET=utf8mb4

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRY=86400

# Email Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your_email@business.onyxtechpay.com
MAIL_PASSWORD=your_email_password
MAIL_FROM_ADDRESS=noreply@business.onyxtechpay.com
MAIL_FROM_NAME=ONYX Accounting

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_UPLOAD_TYPES=pdf,jpg,jpeg,png,doc,docx,xls,xlsx

# Application Settings
TIMEZONE=Africa/Kampala
CURRENCY=UGX
